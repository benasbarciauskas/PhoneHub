# Normalize line endings to LF on checkin.
* text=auto eol=lf

# Explicitly treat known text types as text.
*.swift text
*.sh    text
*.md    text
*.yml   text
*.yaml  text
*.json  text
*.html  text
*.svg   text
*.plist text

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.icns binary

# Linguist: docs site shouldn't dominate language stats.
docs/** linguist-documentation=true
